# Sidereal Controller Manager
# FIPS 140-2 validated build: BoringCrypto (CMVP #3678)
#
# Build: docker build -t ghcr.io/primaris-tech/sidereal-controller:latest -f build/Dockerfile.controller .

FROM golang:1.25.10 AS builder

WORKDIR /app

# Cache dependency layer
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# BoringCrypto FIPS build — statically linked for distroless/static runtime
# -linkmode external forces the external linker so -extldflags "-static" takes effect
ENV GOEXPERIMENT=boringcrypto CGO_ENABLED=1
RUN go build -trimpath -ldflags '-linkmode external -extldflags "-static"' -o controller ./cmd/controller/

# Verify BoringCrypto symbols are linked and binary is statically linked
RUN go tool nm controller | grep -qE '_Cfunc__goboringcrypto_|crypto/internal/boring' \
    || (echo "FATAL: BoringCrypto symbols not found in controller binary" && exit 1)
RUN ! ldd controller 2>/dev/null || (echo "FATAL: controller binary is dynamically linked" && exit 1)

# Runtime stage: static distroless (no glibc, no shell)
FROM gcr.io/distroless/static-debian12:nonroot

LABEL org.opencontainers.image.title="sidereal-controller" \
      org.opencontainers.image.description="Sidereal Controller Manager - Kubernetes security control validation operator" \
      org.opencontainers.image.vendor="Primaris Technologies" \
      org.opencontainers.image.source="https://github.com/primaris-tech/sidereal" \
      org.opencontainers.image.licenses="Apache-2.0" \
      io.sidereal.fips="boringcrypto" \
      io.sidereal.component="controller"

WORKDIR /
COPY --from=builder /app/controller /controller
USER 65532:65532
ENTRYPOINT ["/controller"]
